    "rslib": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:typescript-7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
