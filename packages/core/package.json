{
  "name": "@rslib/core",
  "version": "1.0.0-beta.1",
  "description": "The Rsbuild-based library development tool.",
  "homepage": "https://rslib.rs",
  "bugs": {
    "url": "https://github.com/web-infra-dev/rslib/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rslib.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist-types/index.d.ts",
  "bin": {
    "rslib": "./bin/rslib.js"
  },
  "files": [
    "bin",
    "dist",
    "dist-types",
    "types.d.ts"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch",
    "test": "rstest"
  },
  "dependencies": {
    "@rsbuild/core": "catalog:",
    "rsbuild-plugin-dts": "workspace:*"
  },
  "devDependencies": {
    "@module-federation/rsbuild-plugin": "catalog:",
    "@rslib/tsconfig": "workspace:*",
    "@types/fs-extra": "catalog:",
    "@types/semver": "catalog:",
    "cac": "catalog:",
    "fs-extra": "catalog:",
    "get-tsconfig": "catalog:",
    "memfs": "catalog:",
    "path-serializer": "catalog:",
    "rsbuild-plugin-publint": "catalog:",
    "rslib": "catalog:",
    "rslog": "catalog:",
    "semver": "catalog:",
    "tinyglobby": "catalog:",
    "typescript": "catalog:typescript-7"
  },
  "peerDependencies": {
    "@microsoft/api-extractor": "^7",
    "typescript": "^5 || ^6 || ^7"
  },
  "peerDependenciesMeta": {
    "@microsoft/api-extractor": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
