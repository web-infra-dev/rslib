    "outDir": "./dist",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "./dist-types",
    "isolatedDeclarations": true,
    "composite": true,
    "moduleResolution": "bundler"
  },
  "include": ["src", "types.d.ts"],
