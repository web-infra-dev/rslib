{
  "name": "rslib-svelte-ts",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib && svelte-check --tsconfig ./tsconfig.json",
    "dev": "rslib --watch",
    "type-check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@rsbuild/plugin-svelte": "^1.1.1",
    "@rslib/core": "workspace:*",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "svelte2tsx": "^0.7.55",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
