{
  "extends": "@rslib/tsconfig/base",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "declaration": true,
    "isolatedDeclarations": true,
    "composite": true,
    "moduleResolution": "bundler",
    "paths": {
      "tsconfig-paths": ["./compiled/tsconfig-paths"]
    }
  },
  "include": ["src"],
  "exclude": ["**/node_modules"]
}
