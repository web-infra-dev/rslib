{
  "compilerOptions": {
    "lib": ["DOM", "ES2022"],
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "rootDir": "src"
  },
  "include": ["src"]
}
