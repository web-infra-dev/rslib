{
  "name": "create-rslib",
  "version": "1.0.0-beta.1",
  "description": "Create a new Rslib project",
  "homepage": "https://rslib.rs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rslib.git",
    "directory": "packages/create-rslib"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
