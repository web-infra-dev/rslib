{
  "compilerOptions": {
    "lib": ["DOM", "ES2022"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "types": ["@rslib/core/types"],
    "rootDir": "src"
  },
  "include": ["src"]
}
