{
  "compilerOptions": {
    "rootDir": "src",
    "skipLibCheck": true,
    "paths": {
      "@src/*": ["./src/*"],
      "prebundle-pkg": ["./compile/prebundle-pkg"],
      "types-pkg": ["./compile/types-pkg/types"],
      "self-entry": ["./src"],
      "*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
