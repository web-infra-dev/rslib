{
  "extends": "@rslib/tsconfig/base",
  "compilerOptions": {
    "noEmit": true,
    "composite": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx"
  },
  "include": [
    "../rstest.config.ts",
    "*.ts",
    "scripts/**/*.ts",
    "benchmark/**/*.ts",
    "e2e/**/*",
    "integration/**/*.test.*",
    "integration/**/*.config.*"
  ],
  "exclude": ["**/node_modules", "**/.*/"],
  "references": [
    {
      "path": "../packages/core"
    }
  ]
}
